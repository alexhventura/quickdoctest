# Google OAuth — Web Client ID (origens: localhost:5173, www/quickdoctest.com, vercel.app)
VITE_GOOGLE_CLIENT_ID=

# Google Analytics 4 — Measurement ID (G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# Google Search Console — meta content value only
VITE_GOOGLE_SITE_VERIFICATION=

# Google AdSense (optional — placeholders shown until configured)
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_SLOT=

# EmailJS (optional — result email)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
